  header "Neovim F-Keys"
  entry "F1"   "WhichKey (show all keymaps)"
  entry "F2"   "Rename symbol (LSP)"
  entry "F3"   "Format file"
  entry "F4"   "Code action"
  entry "F5"   "Search in project (grep)"
  entry "F6"   "Find files"
  entry "F7"   "Switch buffer"
  entry "F8"   "Toggle Neo-tree explorer"
  entry "F9"   "Toggle terminal (vertical)"
  entry "F10"  "LazyGit"
}

section_neotree() {
  header "Neo-tree (in explorer)"
  entry "F8"        "Toggle Neo-tree (show/hide)"
  entry "Enter"     "Open file / expand directory"
  entry "Backspace" "Collapse directory / go to parent"
  entry "W"         "Collapse all open directories"
  entry "e"         "Toggle auto-expand width"
  entry "P"         "Toggle preview"
  entry "a"         "Add file/directory"
  entry "d"         "Delete"
  entry "r"         "Rename"
  entry "m"         "Move (rename with path)"
  entry "c / x / p" "Copy / cut / paste"
  entry "y"         "Copy file path to clipboard"
  entry "Y"         "Copy relative path"
  entry "s"         "Open in vertical split"
  entry "S"         "Open in horizontal split"
  entry "H"         "Toggle hidden files"
  entry "/"         "Filter / search nodes"
  entry "R"         "Refresh tree"
  entry "?"         "Show all Neo-tree keymaps"
}

section_lsp() {
  header "Neovim LSP & Navigation"
  entry "gd"          "Go to definition"
  entry "gr"          "Find references"
  entry "gI"          "Go to implementation"
  entry "gy"          "Go to type definition"
  entry "K"           "Hover documentation"
  entry "Ctrl-o"      "Jump back"
  entry "Ctrl-i"      "Jump forward"
  entry "<leader>fp"  "Find project files"
  entry "<leader>fP"  "Search project text"
}

section_diagnostics() {
  header "Neovim Diagnostics"
  entry "]d / [d"     "Next / previous diagnostic"
  entry "<leader>ud"  "Toggle all diagnostics on/off"
  entry "<leader>md"  "Toggle diagnostics (prose buffers only)"
  entry "<leader>cd"  "Line diagnostics float"
  entry "<leader>xd"  "Document diagnostics (trouble)"
  entry "<leader>xw"  "Workspace diagnostics (trouble)"
  entry "<leader>xx"  "Toggle trouble list"
  entry "<leader>fw"  "Toggle word wrap"
}

section_vim() {
  header "Vim Essentials"
  entry "i / a / o"    "Insert / append / open line"
  entry "Esc"          "Back to normal mode"
  entry ":w / :q / :wq" "Save / quit / save+quit"
  entry ":QuitFile"    "Close current buffer (keeps Neo-tree)"
  entry ":QuitFiles"   "Close all buffers (keeps Neo-tree)"
  entry "/ n N"        "Search, next, previous"
  entry "u / Ctrl-r"   "Undo / redo"
  entry "yy / dd / p"  "Yank line / delete line / paste"
  entry "ciw"          "Change inner word"
  entry "di( / di\""   "Delete inside parens / quotes"
  entry "w / b"        "Word forward / back"
  entry "gg / G"       "Top / bottom of file"
  entry "%"            "Jump to matching bracket"
  entry "*"            "Search word under cursor"
  entry ":vs / :sp"    "Vertical / horizontal split"
  entry "Ctrl-h/j/k/l" "Move between splits"
}

section_shell() {
  header "Shell Aliases & Commands"
  entry "dev"            "Open project picker / tmux session"
  entry "dev install --local" "Install from this local clone"
  entry "dev session list" "List tmux sessions"
  entry "dev session kill -s" "Kill tmux session(s)"
  entry "dev --refresh"   "Re-apply layout to current session"
  entry "dev --restart"   "Kill and restart current session"
  entry "dev --resume"    "Reopen all sessions as Kitty tabs"
  entry "dev --workspace" "Load tmuxp workspace YAML"
  entry "v / vim"        "Open Neovim"
  entry "lg"             "Open LazyGit"
  entry "tl"             "List tmux sessions"
  entry "ta <name>"      "Attach to tmux session"
  entry "reload"         "Reload shell config"
  entry "localupdate"    "Update dotfiles installation"
  entry "localconfig"    "Edit ~/.localrc"
  entry "cheat"          "This cheatsheet"
}

section_find_replace() {
  header "Vim Find / Replace (no regex)"
  entry ":%s/old/new/g"      "Replace all in file"
  entry ":%s/old/new/gc"     "Replace all, confirm each"
  entry ":s/old/new/g"       "Replace on current line"
  entry "V + :s/old/new/g"   "Replace inside visual selection"
  entry "* then cgn"         "Search word, change next match"
  entry "."                  "Repeat last change (after cgn)"
  entry ":noh"               "Clear search highlight"
  entry "Ctrl-n"             "vim-visual-multi: cursor at next match"
  entry "n / N (in VM)"      "Next / prev match"
  entry "q / Q (in VM)"      "Skip / remove current cursor"
  entry "<leader>sr"         "grug-far: project-wide find/replace UI"
  entry "grug-far flags"     "Add --fixed-strings to disable regex"
  entry "F2"                 "LSP rename symbol (cross-file, semantic)"
}

section_git_diff() {
  header "Git Diff & History"
  entry "]h / [h"            "Next / prev hunk (gitsigns)"
  entry "<leader>ghp"        "Preview hunk inline (gitsigns)"
  entry "<leader>ghs"        "Stage hunk (gitsigns)"
  entry "<leader>ghr"        "Reset hunk (gitsigns)"
  entry "<leader>ghd"        "Diff this file (gitsigns)"
  entry "<leader>ghb"        "Blame current line (gitsigns)"
  entry "<leader>gs"         "Fugitive: git status"
  entry "<leader>gd"         "Fugitive: vertical diff split"
  entry "<leader>gb"         "Fugitive: full-buffer blame"
  entry "<leader>gl"         "Fugitive: commit log"
  entry "F10"                "LazyGit (full TUI)"
  entry "git diff"           "Working tree vs staged"
  entry "git diff --staged"  "Staged vs HEAD"
  entry "git diff main...HEAD" "Branch vs main (since merge base)"
  entry "git diff HEAD~1"    "Vs previous commit"
  entry "git diff --stat"    "Summary (files + line counts only)"
}

section_git_conflict() {
  header "Git Conflict Resolution"
  entry "<<<<<<< ======= >>>>>>>" "Conflict markers in-file"
  entry "/<<<<<<<"           "Search to next conflict"
  entry ":Gvdiffsplit!"      "Fugitive 3-way: HEAD //2 + incoming //3"
  entry ":diffget //2"       "Take HEAD / target side"
  entry ":diffget //3"       "Take incoming / merge side"
  entry "]c / [c"            "Next / prev diff hunk (diff mode)"
  entry "do / dp"            "Diff obtain / put (side-by-side)"
  entry ":Gwrite"            "Save + stage resolved file"
  entry "F10"                "LazyGit: 'M' on file = interactive resolver"
  entry "git status"         "CLI: list conflicted files"
  entry "git checkout --ours <f>"   "Keep our side wholesale"
  entry "git checkout --theirs <f>" "Keep their side wholesale"
  entry "git mergetool"      "Launch external mergetool"
  entry "git merge --abort"  "Bail out, restore pre-merge state"
  entry "git rerere"         "Reuse recorded resolutions next time"
}

show_all() {
  printf '\n%b%b  Terminal Workflow Cheatsheet%b\n' "$BOLD" "$GREEN" "$RESET"
  section_kitty
  section_tmux
  section_tmux_copy
  section_nvim_fkeys
  section_neotree
  section_lsp
  section_diagnostics
  section_vim
  section_find_replace
  section_git_diff
  section_git_conflict
  section_shell
  printf '\n'
}

usage() {
  cat <<'EOF'
Usage: cheat [section]

Sections: kitty, tmux, copy, nvim, neotree, lsp, diag,
          vim, replace, gitdiff, conflict, shell, all (default)
EOF
}

case "${1:-all}" in
  kitty)          section_kitty; printf '\n' ;;
  tmux)           section_tmux; printf '\n' ;;
  copy)           section_tmux_copy; printf '\n' ;;
  nvim|neovim|fkeys) section_nvim_fkeys; printf '\n' ;;
  neotree|tree|explorer) section_neotree; printf '\n' ;;
  lsp)            section_lsp; printf '\n' ;;
  diag|diagnostics) section_diagnostics; printf '\n' ;;
  vim)            section_vim; printf '\n' ;;
  replace|findreplace|sub) section_find_replace; printf '\n' ;;
  gitdiff|diff)   section_git_diff; printf '\n' ;;
  conflict|gitconflict|merge) section_git_conflict; printf '\n' ;;
  shell|alias*)   section_shell; printf '\n' ;;
  all)            show_all ;;
  -h|--help)      usage ;;
  *)
    printf 'Unknown section: %s\n\n' "$1" >&2
    usage >&2
    exit 1
    ;;
esac
