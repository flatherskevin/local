#!/usr/bin/env bash

set -euo pipefail

for cmd in fd fzf tmux; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf '%s is required but not installed\n' "$cmd" >&2
    exit 1
  fi
done

usage() {
  cat <<'EOF'
Usage:
  dev [path]                       Open the current Git repo, or pick a project directory
  dev install --local              Install your real setup from the current local clone
  dev session list [--filter TEXT] List tmux sessions managed by dev/tmux
  dev session kill -s NAME...      Kill one or more tmux sessions by name
  dev more [--session NAME]        Open a new Kitty tab of terminals for a workstream
  dev --refresh                    Re-apply layout and settings to the current tmux session
  dev --restart                    Kill current session and start a fresh one for the same project
  dev --resume                     Reopen all tmux sessions as Kitty tabs
  dev --workspace FILE             Load a tmuxp workspace YAML file
EOF
}

sanitize_session_name() {
  local input="$1"
  printf '%s' "$input" | tr '/ .:@' '-----' | tr -cd '[:alnum:]_-'
}

session_hash() {
  local input="$1"
  printf '%s' "$input" | shasum -a 256 | cut -c1-6
}

session_name_for_project() {
  local project="$1"
  local base hash
  base="$(sanitize_session_name "$(basename "$project")")"
  hash="$(session_hash "$project")"
  printf '%s-%s\n' "$base" "$hash"
}

companion_name() {
  local parent="$1" slot="$2"
  printf '%s+%s\n' "$parent" "$slot"
}

is_companion() {
  [[ "$1" =~ \+[0-9]+$ ]]
}

parent_of_session() {
  local name="$1"
  printf '%s\n' "${name%+[0-9]*}"
}

companions_of() {
  local parent="$1"
  list_sessions | grep -E "^${parent}\+[0-9]+$" || true
}

next_companion_slot() {
  local parent="$1"
  local name slots n
  # Collect used slot numbers (no associative arrays; macOS ships bash 3.2).
  slots="$(
    while IFS= read -r name; do
      [[ -z "$name" ]] && continue
      printf '%s\n' "${name##*+}"
    done < <(companions_of "$parent") | sort -n
  )"
  n=1
  while printf '%s\n' "$slots" | grep -qx "$n"; do
    n=$((n + 1))
  done
  printf '%s\n' "$n"
}

list_roots() {
  local candidates=(
    "$PWD"
    "$HOME/code"
    "$HOME/codebase"
    "$HOME/dev"
    "$HOME/src"
    "$HOME/work"
    "$HOME/workspace"
    "$HOME/Documents/code"
  )

  for root in "${candidates[@]}"; do
    [[ -d "$root" ]] && printf '%s\n' "$root"
  done
}

list_projects() {
  local root
  while IFS= read -r root; do
    fd --type d --max-depth 1 . "$root"
  done < <(list_roots)
}

pick_project() {
  local projects
  projects="$(list_projects | sort -u)"

  if [[ -z "$projects" ]]; then
    printf 'No project directories found. Searched under:\n' >&2
    list_roots | sed 's/^/  /' >&2
    exit 1
  fi

  printf '%s\n' "$projects" | fzf --prompt='Project > ' --height=50% --layout=reverse --border
}

current_git_project() {
  git rev-parse --show-toplevel 2>/dev/null || true
}

current_git_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'HEAD\n'
}

warn_if_dirty_worktree() {
  if ! git diff --quiet --ignore-submodules HEAD -- 2>/dev/null || [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    printf '[warning] local install testing clones committed Git state only; uncommitted changes are not included\n' >&2
  fi
}

list_sessions() {
  tmux list-sessions -F '#{session_name}' 2>/dev/null || true
}

filter_sessions() {
  local filter="${1:-}"

  if [[ -z "$filter" ]]; then
    list_sessions
  else
    list_sessions | grep -F "$filter" || true
  fi
}

pick_session() {
  local filter="${1:-}"
  local sessions
  sessions="$(filter_sessions "$filter")"

  if [[ -z "$sessions" ]]; then
    printf 'No tmux sessions found\n' >&2
    exit 1
  fi

  printf '%s\n' "$sessions" | fzf --prompt='Session > ' --height=50% --layout=reverse --border
}

reload_nvim() {
  local session="$1"
  local pane="${session}:1.1"
  local pane_cmd
  pane_cmd="$(tmux display-message -t "$pane" -p '#{pane_current_command}' 2>/dev/null || true)"
  if [[ "$pane_cmd" == "nvim" || "$pane_cmd" == "vim" ]]; then
    tmux send-keys -t "$pane" Escape ":silent! wa | qa!" C-m
    sleep 0.5
    tmux send-keys -t "$pane" "nvim" C-m
  fi
}

apply_settings() {
  local session="$1"
  tmux source-file ~/.config/tmux/tmux.conf
  tmux set-window-option -t "${session}:1" main-pane-width 66%
  tmux select-layout -t "${session}:1" main-vertical
  tmux set-hook -t "$session" window-resized "select-layout main-vertical"
}

create_session() {
  local session="$1" project="$2"
  tmux new-session -d -s "$session" -c "$project"
  tmux split-window -h -c "$project" -t "${session}:1"
  tmux split-window -v -p 50 -c "$project" -t "${session}:1.2"
  apply_settings "$session"
  tmux send-keys -t "${session}:1.1" "nvim" C-m
  tmux select-pane -t "${session}:1.2"
}

create_companion_session() {
  local session="$1" project="$2" count="$3"
  local i
  tmux new-session -d -s "$session" -c "$project"
  for ((i = 1; i < count; i++)); do
    tmux split-window -c "$project" -t "${session}:1"
    tmux select-layout -t "${session}:1" tiled
  done
  tmux source-file ~/.config/tmux/tmux.conf
  tmux select-layout -t "${session}:1" tiled
  tmux set-hook -t "$session" window-resized "select-layout tiled"
  tmux select-pane -t "${session}:1.1"
}

kitty_remote_available() {
  command -v kitty >/dev/null 2>&1 && kitty @ ls >/dev/null 2>&1
}

set_current_tab_title() {
  local title="$1"

  if [[ -n "${KITTY_WINDOW_ID:-}" ]] && kitty_remote_available; then
    kitty @ set-tab-title "$title" >/dev/null 2>&1 || true
  fi
}

# Detached companions of PARENT, reusing the tested companions_of helper.
detached_companions() {
  local parent="$1" name attached
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    attached="$(tmux display-message -p -t "$name" '#{session_attached}' 2>/dev/null || true)"
    [[ "$attached" == "0" ]] && printf '%s\n' "$name"
  done < <(companions_of "$parent")
}

parse_picker_selection() {
  local line="$1"
  printf '%s\n' "${line%%[[:space:]]*}"
}

# Decides what `dev more` should do. Prints "NEW", the chosen companion name, or
# nothing (when the picker is cancelled). Falls back to "NEW" when nothing is
# detached or when fzf is unavailable.
pick_companion_action() {
  local parent="$1" next_slot="$2"
  local detached menu name panes selection
  detached="$(detached_companions "$parent")"

  if [[ -z "$detached" ]] || ! command -v fzf >/dev/null 2>&1; then
    printf 'NEW\n'
    return 0
  fi

  # Build the fzf menu at function scope (avoids `local` inside a subshell).
  # Each line is "KEY<TAB>LABEL"; KEY is "NEW" or a session name (never has spaces).
  menu="$(printf 'NEW\t* New companion (+%s)' "$next_slot")"
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    panes="$(tmux list-panes -t "$name" 2>/dev/null | wc -l | tr -d ' ')"
    menu+="$(printf '\n%s\t+%s . %s panes' "$name" "${name##*+}" "$panes")"
  done <<< "$detached"

  # The fzf --preview string is a snippet fzf re-evaluates per row, so its $sel,
  # {1}, and #{...} placeholders must stay literal (single-quoted) here.
  # shellcheck disable=SC2016
  selection="$(printf '%s\n' "$menu" | fzf --delimiter='\t' --with-nth=2.. \
      --prompt='Companion > ' --height=50% --layout=reverse --border \
      --preview 'sel={1}; if [ "$sel" = NEW ]; then echo "Open a new tab of terminals."; else tmux list-panes -t "$sel" -F "#{pane_index}: #{pane_current_command}  (#{pane_current_path})" 2>/dev/null; fi' \
      --preview-window='right,45%')" || true

  if [[ -z "$selection" ]]; then
    # Picker cancelled (Escape).
    return 0
  fi

  parse_picker_selection "$selection"
}

open_companion_tab() {
  local name="$1"
  if [[ -n "${KITTY_WINDOW_ID:-}" ]] && kitty_remote_available; then
    kitty @ launch --type=tab --tab-title "$name" tmux attach-session -t "$name"
  else
    printf 'Kitty remote control is unavailable; attach with: tmux attach-session -t %s\n' "$name" >&2
  fi
}

dev_more_command() {
  local parent="" count=4 force_new=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        parent="${2:-}"
        if [[ -z "$parent" ]]; then
          printf 'Usage: dev more [--session NAME] [--count N] [--new]\n' >&2
          exit 1
        fi
        shift 2
        ;;
      --count)
        count="${2:-}"
        if [[ ! "$count" =~ ^[0-9]+$ ]] || [[ "$count" -lt 1 ]]; then
          printf 'dev more: --count must be a positive integer\n' >&2
          exit 1
        fi
        shift 2
        ;;
      --new)
        force_new=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage: dev more [--session NAME] [--count N] [--new]

Open a new Kitty tab of terminals tied to a workstream (a "companion" session).

Options:
  --session NAME  Parent session id (e.g. repo-56e811). Defaults to the current
                  tmux session when run inside one.
  --count N       Number of terminal panes in the new tab (default 4).
  --new           Skip the resume picker and always create a fresh companion.
EOF
        exit 0
        ;;
      *)
        printf 'Unknown option for dev more: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$parent" ]]; then
    if [[ -n "${TMUX:-}" ]]; then
      parent="$(parent_of_session "$(tmux display-message -p '#S')")"
    else
      printf 'dev more: provide --session NAME or run inside a tmux session\n' >&2
      exit 1
    fi
  fi

  if ! tmux has-session -t "$parent" 2>/dev/null; then
    printf 'dev more: no tmux session named: %s\n' "$parent" >&2
    exit 1
  fi

  local project
  project="$(tmux display-message -p -t "$parent" '#{session_path}')"
  if [[ -z "$project" ]]; then
    project="$(tmux display-message -p -t "$parent" '#{pane_current_path}')"
  fi

  local next_slot action target
  next_slot="$(next_companion_slot "$parent")"

  if [[ "$force_new" -eq 1 ]]; then
    action="NEW"
  else
    action="$(pick_companion_action "$parent" "$next_slot")"
  fi

  if [[ -z "$action" ]]; then
    # Picker cancelled.
    exit 0
  fi

  if [[ "$action" == "NEW" ]]; then
    target="$(companion_name "$parent" "$next_slot")"
    create_companion_session "$target" "$project" "$count"
  else
    target="$action"
  fi

  open_companion_tab "$target"
}

session_list_command() {
  local filter=""
  local sessions

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter)
        filter="${2:-}"
        if [[ -z "$filter" ]]; then
          printf 'Usage: dev session list [--filter TEXT]\n' >&2
          exit 1
        fi
        shift 2
        ;;
      -h|--help)
        printf 'Usage: dev session list [--filter TEXT]\n'
        exit 0
        ;;
      *)
        printf 'Unknown option for session list: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  sessions="$(list_sessions)"
  if [[ -z "$sessions" ]]; then
    printf 'No tmux sessions found\n' >&2
    exit 1
  fi

  sessions="$(filter_sessions "$filter")"
  printf '%s\n' "$sessions"
}

session_kill_command() {
  local -a targets=()
  local status=0
  local target

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session)
        if [[ -z "${2:-}" ]]; then
          printf 'Usage: dev session kill --session NAME [--session NAME ...]\n' >&2
          exit 1
        fi
        targets+=("$2")
        shift 2
        ;;
      -h|--help)
        printf 'Usage: dev session kill --session NAME [--session NAME ...]\n'
        exit 0
        ;;
      *)
        printf 'Unknown option for session kill: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  if [[ ${#targets[@]} -eq 0 ]]; then
    if [[ -t 0 && -t 1 ]]; then
      targets+=("$(pick_session)")
    else
      printf 'Usage: dev session kill --session NAME [--session NAME ...]\n' >&2
      exit 1
    fi
  fi

  for target in "${targets[@]}"; do
    if tmux has-session -t "$target" 2>/dev/null; then
      tmux kill-session -t "$target"
      printf 'Removed tmux session: %s\n' "$target"
    else
      printf 'No tmux session named: %s\n' "$target" >&2
      status=1
    fi
  done

  exit "$status"
}

install_local_command() {
  local repo_root branch with_ai=0 install_base

  repo_root="$(current_git_project)"
  if [[ -z "$repo_root" ]]; then
    printf 'dev install --local must be run from inside a Git repository\n' >&2
    exit 1
  fi

  branch="$(current_git_branch)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ref)
        branch="${2:-}"
        if [[ -z "$branch" ]]; then
          printf 'Usage: dev install --local [--ref REF] [--with-ai]\n' >&2
          exit 1
        fi
        shift 2
        ;;
      --with-ai)
        with_ai=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage: dev install --local [--ref REF] [--with-ai]

Defaults:
  --ref       current Git branch

Notes:
  - Uses this local clone as the managed installer source.
  - Clones committed Git state only; uncommitted changes are not included.
EOF
        exit 0
        ;;
      *)
        printf 'Unknown option for dev install --local: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  warn_if_dirty_worktree
  install_base="${LOCAL_BASE_DIR:-$HOME/.flatherskevin}"

  printf '[local-install] repo: %s\n' "$repo_root"
  printf '[local-install] ref: %s\n' "$branch"
  printf '[local-install] target home: %s\n' "$HOME"
  printf '[local-install] install base: %s\n' "$install_base"

  (
    cd "$repo_root"
    LOCAL_BASE_DIR="$install_base" \
    LOCAL_REPO_URL="file://${repo_root}" \
    LOCAL_INSTALL_REF="$branch" \
    LOCAL_INSTALL_AI_CLI="$with_ai" \
    ./install.sh
  )
}

# When this file is sourced (e.g. by scripts/test-dev-more.sh) rather than
# executed, stop here so only the function definitions above are loaded.
if [[ "${BASH_SOURCE[0]:-}" != "${0}" ]]; then
  return 0
fi

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "session" ]]; then
  subcommand="${2:-}"
  case "$subcommand" in
    list)
      shift 2
      session_list_command "$@"
      ;;
    kill)
      shift 2
      session_kill_command "$@"
      ;;
    *)
      printf 'Usage: dev session {list|kill} ...\n' >&2
      exit 1
      ;;
  esac
  exit 0
fi

if [[ "${1:-}" == "more" ]]; then
  shift
  dev_more_command "$@"
  exit 0
fi

if [[ "${1:-}" == "install" ]]; then
  shift
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || -z "${1:-}" ]]; then
    printf 'Usage: dev install --local [--ref REF] [--with-ai]\n'
    exit 0
  fi
  if [[ "${1:-}" == "--local" ]]; then
    shift
    install_local_command "$@"
  else
    printf 'Usage: dev install --local [--ref REF] [--with-ai]\n' >&2
    exit 1
  fi
  exit 0
fi

if [[ "${1:-}" == "--restart" ]]; then
  if [[ -z "${TMUX:-}" ]]; then
    printf 'Not inside a tmux session\n' >&2
    exit 1
  fi
  project="$(tmux display-message -p '#{session_path}')"
  old_session="$(tmux display-message -p '#S')"
  session_name="$(session_name_for_project "$project")"
  temp_name="${session_name}-restarting"
  create_session "$temp_name" "$project"
  tmux switch-client -t "$temp_name"
  tmux kill-session -t "$old_session"
  tmux rename-session -t "$temp_name" "$session_name"
  exit 0
fi

if [[ "${1:-}" == "--workspace" ]]; then
  if ! command -v tmuxp >/dev/null 2>&1; then
    printf 'tmuxp is required but not installed. Run: brew install tmuxp\n' >&2
    exit 1
  fi
  ws_file="${2:-}"
  if [[ -z "$ws_file" ]]; then
    printf 'Usage: dev --workspace <file.yaml>\n' >&2
    exit 1
  fi
  if [[ ! -f "$ws_file" ]]; then
    printf 'Workspace file not found: %s\n' "$ws_file" >&2
    exit 1
  fi
  tmuxp load -d "$ws_file"

  session_name="$(yq -r '.session_name' "$ws_file")"
  if [[ -z "$session_name" || "$session_name" == "null" ]]; then
    printf 'Could not read session_name from %s\n' "$ws_file" >&2
    exit 1
  fi

  if ! kitty_remote_available; then
    printf 'Kitty remote control is unavailable; attach manually with: tmux attach-session -t %s\n' "$session_name" >&2
    exit 1
  fi

  kitty @ launch --type=os-window --tab-title "$session_name" tmux attach-session -t "$session_name"
  exit 0
fi

if [[ "${1:-}" == "--resume" ]]; then
  sessions="$(list_sessions)"
  if [[ -z "$sessions" ]]; then
    printf 'No tmux sessions to resume\n' >&2
    exit 1
  fi
  if ! kitty_remote_available; then
    printf 'Kitty remote control is unavailable; attach sessions manually with tmux attach-session\n' >&2
    exit 1
  fi
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    kitty @ launch --type=tab --tab-title "$session" tmux attach-session -t "$session"
  done <<< "$sessions"
  exit 0
fi

if [[ "${1:-}" == "--refresh" ]]; then
  if [[ -z "${TMUX:-}" ]]; then
    printf 'Not inside a tmux session\n' >&2
    exit 1
  fi
  session="$(tmux display-message -p '#S')"
  apply_settings "$session"
  reload_nvim "$session"
  tmux display-message "Settings refreshed"
  exit 0
fi

if [[ -n "${1:-}" ]]; then
  if [[ -d "$1/.git" ]]; then
    project="$(cd "$1" && pwd)"
  elif [[ -d "$1" ]]; then
    project="$(cd "$1" && pwd)"
  else
    printf 'Path does not exist: %s\n' "$1" >&2
    exit 1
  fi
else
  project="$(current_git_project)"
  if [[ -z "$project" ]]; then
    project="$(pick_project)"
  fi
fi

if [[ -z "$project" ]]; then
  exit 0
fi

project="${project%/}"
session_name="$(session_name_for_project "$project")"

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  create_session "$session_name" "$project"
fi

if [[ -n "${TMUX:-}" ]]; then
  tmux switch-client -t "$session_name"
else
  set_current_tab_title "$session_name"
  exec tmux attach-session -t "$session_name"
fi
